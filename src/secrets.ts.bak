// Dynamic registry for MCP and plugin secrets
const dynamicSecrets: SecretDef[] = [];

/**
 * Register a new secret requirement (called by MCP/plugin loaders).
 */
export function registerSecret(def: SecretDef): void {
  if (!SECRET_REGISTRY.find(s => s.key === def.key) && !dynamicSecrets.find(s => s.key === def.key)) {
    dynamicSecrets.push(def);
    logger.info({ key: def.key, feature: def.feature }, 'Dynamic secret registered');
  }
}

/**
 * Get all known secret definitions.
 */
export function getAllSecretDefs(): SecretDef[] {
  return [...SECRET_REGISTRY, ...dynamicSecrets];
}

// ── Encryption ───────────────────────────────────────────────────────

function getEncryptionKey(): Buffer {
  const envSecrets = readEnvFile(['DB_ENCRYPTION_KEY']);
  const keyHex = envSecrets.DB_ENCRYPTION_KEY || process.env.DB_ENCRYPTION_KEY;
  if (!keyHex || keyHex.length < 32) {
    // Use a fallback derived from machine identity
    const fallback = crypto.createHash('sha256')
      .update(`wild-claude-pi-${process.env.USERNAME || 'default'}`)
      .digest();
    return fallback;
  }
  return Buffer.from(keyHex.slice(0, 64), 'hex');
}

function encrypt(text: string): { iv: string; data: string; tag: string } {
  const key = getEncryptionKey();
  const iv = crypto.randomBytes(16);
  const cipher = crypto.createCipheriv(ALGORITHM, key, iv);
  let encrypted = cipher.update(text, 'utf-8', 'hex');
  encrypted += cipher.final('hex');
  const tag = cipher.getAuthTag();
  return { iv: iv.toString('hex'), data: encrypted, tag: tag.toString('hex') };
}

function decrypt(enc: { iv: string; data: string; tag: string }): string {
  const key = getEncryptionKey();
  const decipher = crypto.createDecipheriv(ALGORITHM, key, Buffer.from(enc.iv, 'hex'));
  decipher.setAuthTag(Buffer.from(enc.tag, 'hex'));
  let decrypted = decipher.update(enc.data, 'hex', 'utf-8');
  decrypted += decipher.final('utf-8');
  return decrypted;
}

// ── Store operations ─────────────────────────────────────────────────

interface SecretsStore {
  version: number;
  secrets: Record<string, { iv: string; data: string; tag: string }>;
}

function loadStore(): SecretsStore {
  try {
    if (fs.existsSync(SECRETS_FILE)) {
      return JSON.parse(fs.readFileSync(SECRETS_FILE, 'utf-8'));
    }
  } catch (err) {
    logger.warn({ err }, 'Failed to load secrets store, starting fresh');
  }
  return { version: 1, secrets: {} };
}

function saveStore(store: SecretsStore): void {
  fs.mkdirSync(path.dirname(SECRETS_FILE), { recursive: true });
  fs.writeFileSync(SECRETS_FILE, JSON.stringify(store, null, 2), { mode: 0o600 });
}

/**
 * Store a secret (encrypted).
 */
export function setSecret(key: string, value: string): void {
  const store = loadStore();
  store.secrets[key] = encrypt(value);
  saveStore(store);
  logger.info({ key }, 'Secret stored');
}

/**
 * Retrieve a secret. Resolution: encrypted store → .env → env var.
 */
export function getSecret(key: string): string | undefined {
  // 1. Encrypted store
  const store = loadStore();
  if (store.secrets[key]) {
    try {
      return decrypt(store.secrets[key]);
    } catch {
      logger.warn({ key }, 'Failed to decrypt secret, trying .env fallback');
    }
  }

  // 2. .env file
  const envSecrets = readEnvFile([key]);
  if (envSecrets[key]) return envSecrets[key];

  // 3. Environment variable
  if (process.env[key]) return process.env[key];

  return undefined;
}

/**
 * Delete a secret from the encrypted store.
 */
export function deleteSecret(key: string): boolean {
  const store = loadStore();
  if (store.secrets[key]) {
    delete store.secrets[key];
    saveStore(store);
    return true;
  }
  return false;
}

/**
 * Check which secrets are missing (have no value anywhere).
 */
export function getMissingSecrets(requiredOnly = false): SecretDef[] {
  const allDefs = getAllSecretDefs();
  const filtered = requiredOnly ? allDefs.filter(d => d.required) : allDefs;
  return filtered.filter(def => {
    const value = getSecret(def.key);
    return !value || value.trim() === '';
  });
}

/**
 * Check which optional features could be enabled with additional secrets.
 */
export function getAvailableUpgrades(): Array<{ feature: string; secrets: SecretDef[] }> {
  const missing = getMissingSecrets(false).filter(d => !d.required);
  const byFeature = new Map<string, SecretDef[]>();
  for (const def of missing) {
    if (!byFeature.has(def.feature)) byFeature.set(def.feature, []);
    byFeature.get(def.feature)!.push(def);
  }
  return Array.from(byFeature.entries()).map(([feature, secrets]) => ({ feature, secrets }));
}

/**
 * Get a summary of all secrets and their status (set/missing).
 */
export function getSecretsStatus(): Array<{ key: string; name: string; feature: string; set: boolean; required: boolean }> {
  return getAllSecretDefs().map(def => ({
    key: def.key,
    name: def.name,
    feature: def.feature,
    set: !!getSecret(def.key),
    required: def.required,
  }));
}

// ── Telegram commands ────────────────────────────────────────────────

/** Pending secret input: chatId → key being set */
const pendingSecretInput = new Map<string, string>();

export function registerSecretsCommands(bot: Bot<Context>): void {

  // /secrets — show status of all secrets
  bot.command('secrets', async (ctx) => {
    const status = getSecretsStatus();
    const lines = status.map(s => {
      const icon = s.set ? '✅' : (s.required ? '❌' : '⬜');
      return `${icon} ${s.name} (${s.feature})`;
    });

    const missing = getMissingSecrets(true);
    let msg = `Secrets Status:\n\n${lines.join('\n')}`;

    if (missing.length > 0) {
      msg += `\n\n❌ ${missing.length} required secret(s) missing. Use /set_secret <name> to configure.`;
    }

    const upgrades = getAvailableUpgrades();
    if (upgrades.length > 0) {
      msg += '\n\nOptional features you can enable:';
      for (const u of upgrades) {
        msg += `\n- ${u.feature}: needs ${u.secrets.map(s => s.name).join(', ')}`;
      }
    }

    await ctx.reply(msg);
  });

  // /set_secret <KEY> — set a secret value
  bot.command('set_secret', async (ctx) => {
    const key = ctx.match?.trim().toUpperCase();
    if (!key) {
      const defs = getAllSecretDefs();
      const list = defs.map(d => `- ${d.key}: ${d.description}`).join('\n');
      await ctx.reply(`Usage: /set_secret <KEY>\n\nAvailable keys:\n${list}`);
      return;
    }

    const def = getAllSecretDefs().find(d => d.key === key);
    if (!def) {
      await ctx.reply(`Unknown secret: ${key}. Use /secrets to see available keys.`);
      return;
    }

    pendingSecretInput.set(ctx.chat!.id.toString(), key);

    let msg = `Send me the value for ${def.name}.\n\n${def.description}`;
    if (def.obtainUrl) {
      msg += `\n\nGet it here: ${def.obtainUrl}`;
    }
    msg += '\n\n(The message will be deleted after I save it for security)';

    await ctx.reply(msg);
  });

  // /delete_secret <KEY> — remove a stored secret
  bot.command('delete_secret', async (ctx) => {
    const key = ctx.match?.trim().toUpperCase();
    if (!key) {
      await ctx.reply('Usage: /delete_secret <KEY>');
      return;
    }
    if (deleteSecret(key)) {
      await ctx.reply(`Deleted: ${key}`);
    } else {
      await ctx.reply(`${key} was not in the encrypted store (may still be in .env).`);
    }
  });

  // Middleware: intercept secret value input
  bot.on('message:text', async (ctx, next) => {
    const chatId = ctx.chat!.id.toString();
    const pendingKey = pendingSecretInput.get(chatId);

    if (pendingKey) {
      const value = ctx.message.text?.trim();
      if (!value || value.startsWith('/')) {
        pendingSecretInput.delete(chatId);
        return next();
      }

      // Validate if pattern exists
      const def = getAllSecretDefs().find(d => d.key === pendingKey);
      if (def?.pattern && !def.pattern.test(value)) {
        await ctx.reply(`That doesn't look like a valid ${def.name}. Expected format: ${def.pattern}. Try again or /cancel.`);
        return;
      }

      // Store it
      setSecret(pendingKey, value);
      pendingSecretInput.delete(chatId);

      // Try to delete the user's message (contains the secret)
      try {
        await ctx.api.deleteMessage(ctx.chat!.id, ctx.message.message_id);
      } catch {
        // Can't delete — bot may not be admin
      }

      await ctx.reply(`✅ ${def?.name || pendingKey} saved. Active immediately for dashboards and API calls.\n\n(MCP servers need a restart to pick up new keys.)`);
      return;
    }

    return next();
  });
}

/**
 * Check for missing required secrets and return a prompt message, or null if all good.
 */
export function checkMissingSecretsMessage(): string | null {
  const missing = getMissingSecrets(true);
  if (missing.length === 0) return null;

  const lines = missing.map(m => {
    let line = `- ${m.name}: ${m.description}`;
    if (m.obtainUrl) line += ` (${m.obtainUrl})`;
    return line;
  });

  return (
    `I'm missing some required configuration:\n\n${lines.join('\n')}\n\n` +
    `Use /set_secret <KEY> to configure each one, or add them to your .env file.`
  );
}

/**
 * Auto-generate DB_ENCRYPTION_KEY if not set anywhere.
 */
export function ensureEncryptionKey(): void {
  const existing = getSecret('DB_ENCRYPTION_KEY');
  if (!existing || existing.trim() === '') {
    const key = crypto.randomBytes(32).toString('hex');
    // Write to .env since this is needed before the secrets store can work
    const envPath = path.join(process.cwd(), '.env');
    if (fs.existsSync(envPath)) {
      let content = fs.readFileSync(envPath, 'utf-8');
      if (content.includes('DB_ENCRYPTION_KEY=')) {
        content = content.replace(/DB_ENCRYPTION_KEY=.*/, `DB_ENCRYPTION_KEY=${key}`);
      } else {
        content += `\nDB_ENCRYPTION_KEY=${key}\n`;
      }
      fs.writeFileSync(envPath, content);
    }
    // Also set in process.env so it's available immediately (without re-reading .env)
    process.env.DB_ENCRYPTION_KEY = key;
    logger.info('Auto-generated DB_ENCRYPTION_KEY');
  }

  // Also auto-generate DASHBOARD_TOKEN if empty
  const dashToken = getSecret('DASHBOARD_TOKEN');
  if (!dashToken || dashToken.trim() === '') {
    const token = crypto.randomBytes(24).toString('hex');
    const envPath = path.join(process.cwd(), '.env');
    if (fs.existsSync(envPath)) {
      let content = fs.readFileSync(envPath, 'utf-8');
      if (content.includes('DASHBOARD_TOKEN=')) {
        content = content.replace(/DASHBOARD_TOKEN=.*/, `DASHBOARD_TOKEN=${token}`);
      } else {
        content += `\nDASHBOARD_TOKEN=${token}\n`;
      }
      fs.writeFileSync(envPath, content);
    }
    process.env.DASHBOARD_TOKEN = token;
    logger.info({ port: process.env.DASHBOARD_PORT || 3141 }, 'Auto-generated DASHBOARD_TOKEN. Dashboard: http://localhost:%s', process.env.DASHBOARD_PORT || '3141');
  }
}
