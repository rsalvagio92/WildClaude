/**
 * Secrets manager for WildClaude.
 *
 * Stores API keys and secrets encrypted in ~/.wild-claude-pi/secrets.enc.json.
 * Auto-discovers missing secrets from feature requirements.
 * Provides Telegram commands + dashboard UI for management.
 *
 * Resolution order for any secret:
 *   1. Encrypted secrets store (~/.wild-claude-pi/secrets.enc.json)
 *   2. .env file (project root, backward compat)
 *   3. Environment variable
 *
 * Encryption: AES-256-GCM with key derived from DB_ENCRYPTION_KEY.
 */

import crypto from 'crypto';
import fs from 'fs';
import path from 'path';
import { Bot, Context } from 'grammy';

import { USER_DATA_DIR } from './paths.js';
import { readEnvFile } from './env.js';
import { logger } from './logger.js';

const SECRETS_FILE = path.join(USER_DATA_DIR, 'secrets.enc.json');
const ALGORITHM = 'aes-256-gcm';

// ── Secret registry ──────────────────────────────────────────────────
// Defines all known secrets, their purpose, and which features need them.

export interface SecretDef {
  key: string;
  name: string;
  description: string;
  feature: string;
  required: boolean;
  /** URL where user can get this key */
  obtainUrl?: string;
  /** Validation pattern */
  pattern?: RegExp;
}

