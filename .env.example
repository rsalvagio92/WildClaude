# WildClaude Configuration
# The setup script (bash scripts/bootstrap.sh) fills this automatically.
# Or copy manually: cp .env.example .env

# ── Required ──────────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Get via /chatid command after first run (leave empty for first run)
ALLOWED_CHAT_ID=

# ── Auto-generated (leave empty — created on first run) ──────────
DB_ENCRYPTION_KEY=
DASHBOARD_TOKEN=

# ── Optional: AI ──────────────────────────────────────────────────
# Not needed if using Claude subscription via `claude login`
# Set only if you want to use pay-per-use API instead of subscription
ANTHROPIC_API_KEY=

# ── Optional: Voice ───────────────────────────────────────────────
# Groq Whisper for speech-to-text (https://console.groq.com/keys)
GROQ_API_KEY=
# ElevenLabs for text-to-speech (https://elevenlabs.io/app/settings/api-keys)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Optional: Dashboard ──────────────────────────────────────────
DASHBOARD_PORT=3141

# ── Optional: Integrations ───────────────────────────────────────
# WhatsApp bridge
WHATSAPP_ENABLED=false
# Slack (https://api.slack.com/apps)
SLACK_USER_TOKEN=

# ── Optional: Security ───────────────────────────────────────────
# PIN lock (generate: node -e "console.log(require('crypto').createHash('sha256').update('YOUR_PIN').digest('hex'))")
SECURITY_PIN_HASH=
# Auto-lock after N minutes of inactivity (0 = disabled)
IDLE_LOCK_MINUTES=0
# Emergency kill phrase (sending this stops all agents immediately)
EMERGENCY_KILL_PHRASE=

# ── System ────────────────────────────────────────────────────────
# Timeout for agent queries in ms (default: 1 hour)
AGENT_TIMEOUT_MS=3600000
# Context window limit (default: 1M for Opus)
CONTEXT_LIMIT=1000000
# Message batching window in ms (default: 3s)
BATCH_WINDOW_MS=3000
# Max parallel Haiku sidecar sessions (default: 1)
MAX_SIDECAR_SESSIONS=1
